{
	"include": ["src/*.ts", "dist",  "types"],
	"compilerOptions": {
		"target": "ESNext",
		"outDir": "lib",
		"rootDir": "src",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node", "emscripten"],
		"strict": true,
		"declaration": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"useUnknownInCatchVariables": false,
		"rewriteRelativeImportExtensions": true
	}
}
