{
	"name": "@pbk20191/icodec",
	"version": "0.9.0",
	"private": false,
	"description": "Image encoders & decoders built with WebAssembly",
	"license": "MIT",
	"author": "pbk20191 <contact@pbk20191.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pbk20191/icodec.git"
	},
	"type": "module",
	"scripts": {
		"wasm": "node scripts/build.js",
		"types": "tsc -p tsconfig.json",
		"build": "npm run wasm && npm run types",
		"test-convert": "tsx --test test/test-convert.js",
		"test-leak": "tsx --test test/test-leak.js",
		"test-lossless": "tsx --test test/test-lossless.js",
		"demo": "node scripts/start-demo.js"
	},
	"keywords": [
		"WebAssembly",
		"wasm",
		"image",
		"jpg",
		"png",
		"qoi",
		"webp",
		"heic",
		"avif",
		"jxl",
		"wp2",
		"mozjpeg",
		"vvic",
		"pngquant"
	],
	"files": [
		"versions.json",
		"dist/*.{js,wasm,d.ts}",
		"lib/*.{js,d.ts}",
		"types/*.{d.ts}",
		"types/wasm_type.d.ts"
	],
	"exports": {
		"./versions.json": "./versions.json",
		".": "./lib/index.js",
		"./node": {
			"types": "./lib/index.d.ts",
			"default": "./lib/node.js"
		},
		"./qoi-enc.wasm": "./dist/qoi.wasm",
		"./qoi-dec.wasm": "./dist/qoi.wasm",
		"./png-enc.wasm": "./dist/pngquant_bg.wasm",
		"./png-dec.wasm": "./dist/pngquant_bg.wasm",
		"./jpeg-enc.wasm": "./dist/mozjpeg.wasm",
		"./jpeg-dec.wasm": "./dist/mozjpeg.wasm",
		"./*.wasm": "./dist/*.wasm"
	},
	"devDependencies": {
		"@kaciras/eslint-config-core": "^3.4.1",
		"@kaciras/eslint-config-typescript": "^3.4.1",
		"@kaciras/utilities": "^1.0.5",
		"@types/emscripten": "^1.41.5",
		"@types/node": "^24.12.0",
		"esbench": "^0.8.1",
		"eslint": "^9.39.1",
		"node-addon-api": "^8.6.0",
		"node-gyp": "^12.2.0",
		"pixelmatch": "^7.1.0",
		"sharp": "^0.34.5",
		"smol-toml": "^1.5.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"version-compare": "^3.12.0"
	}
}
